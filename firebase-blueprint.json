{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents an employee or admin in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "email": { "type": "string" },
        "matricule": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "photo_url": { "type": "string" },
        "password_hash": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nom", "prenom", "email", "matricule", "role", "password_hash", "created_at"]
    },
    "Presence": {
      "title": "Presence",
      "description": "Represents a clock-in or clock-out log for an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_nom": { "type": "string" },
        "user_prenom": { "type": "string" },
        "user_matricule": { "type": "string" },
        "user_photo_url": { "type": "string" },
        "station_id": { "type": "string" },
        "station_nom": { "type": "string" },
        "type": { "type": "string", "enum": ["entry", "exit"] },
        "date": { "type": "string" },
        "heure": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "user_nom", "user_prenom", "user_matricule", "user_photo_url", "station_id", "station_nom", "type", "date", "heure", "created_at"]
    },
    "Station": {
      "title": "Station",
      "description": "A recording point for QR code clock-ins.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nom_station": { "type": "string" },
        "token_access": { "type": "string" },
        "active": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nom_station", "token_access", "active", "created_at"]
    },
    "QrToken": {
      "title": "QrToken",
      "description": "A temporary short-lived token generated by a station for clock-in security.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "station_id": { "type": "string" },
        "token": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "expire_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "station_id", "token", "created_at", "expire_at"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "description": "Short-lived 6-digit access code to authorize a kiosk station.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "station_id": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" },
        "is_active": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "station_id", "expires_at", "is_active", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of all user accounts."
    },
    "/presences/{presenceId}": {
      "schema": "Presence",
      "description": "Collection of all clock-in logs."
    },
    "/stations/{stationId}": {
      "schema": "Station",
      "description": "Collection of all recording stations."
    },
    "/qr_tokens/{qrTokenId}": {
      "schema": "QrToken",
      "description": "Temporary verification tokens for QR scanning."
    },
    "/access_codes/{accessCodeId}": {
      "schema": "AccessCode",
      "description": "One-time numeric activation codes."
    }
  }
}
